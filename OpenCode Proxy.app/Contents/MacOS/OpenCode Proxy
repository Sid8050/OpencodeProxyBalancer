#!/bin/bash
PROXY_DIR="$(cd "$(dirname "$0")/../../../.." && pwd)"
PROXY_BIN="$PROXY_DIR/proxy"
PID_FILE="$PROXY_DIR/.proxy.pid"
LOG_FILE="$PROXY_DIR/proxy.log"

start_proxy() {
    if pgrep -f "$PROXY_BIN" > /dev/null 2>&1; then
        osascript -e "display notification \"Already running on port 8320\" with title \"OpenCode Proxy\""
        return
    fi
    cd "$PROXY_DIR"
    nohup "$PROXY_BIN" > "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    sleep 1
    if curl -s http://localhost:8320/health > /dev/null 2>&1; then
        osascript -e "display notification \"Proxy started — port 8320\" with title \"OpenCode Proxy\" sound name \"Pop\""
    else
        osascript -e "display notification \"Failed to start\" with title \"OpenCode Proxy\""
    fi
}

stop_proxy() {
    pkill -f "$PROXY_BIN" 2>/dev/null
    rm -f "$PID_FILE"
    osascript -e "display notification \"Proxy stopped\" with title \"OpenCode Proxy\""
}

status_proxy() {
    if pgrep -f "$PROXY_BIN" > /dev/null 2>&1; then
        osascript -e "display dialog \"✅ Proxy is running on port 8320\nDashboard: http://localhost:8320/dashboard\" with title \"OpenCode Proxy\" buttons {\"Stop\", \"OK\"} default button \"OK\"" 2>/dev/null
        if [ $? -eq 0 ]; then
            RESPONSE=$(osascript -e "button returned of (display dialog \"✅ Proxy is running on port 8320\nDashboard: http://localhost:8320/dashboard\" with title \"OpenCode Proxy\" buttons {\"Stop\", \"OK\"} default button \"OK\")")
            if [ "$RESPONSE" = "Stop" ]; then
                stop_proxy
            fi
        fi
    else
        osascript -e "display dialog \"❌ Proxy is not running\" with title \"OpenCode Proxy\" buttons {\"Start\", \"OK\"} default button \"Start\"" 2>/dev/null
        if [ $? -eq 0 ]; then
            RESPONSE=$(osascript -e "button returned of (display dialog \"❌ Proxy is not running\" with title \"OpenCode Proxy\" buttons {\"Start\", \"OK\"} default button \"Start\")")
            if [ "$RESPONSE" = "Start" ]; then
                start_proxy
            fi
        fi
    fi
}

status_proxy
